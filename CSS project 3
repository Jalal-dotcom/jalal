body {
  margin: 0;
  font-family: Helvetica, Arial, sans-serif;
  color: seashell;
  background-color: black;
  text-align: center;
}

/* Header */
header {
  position: fixed;
  top: 0;
  width: 100%;
  height: 69px;
  background-color: black;
  border-bottom: 1px solid seashell;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

header img {
  height: 50px;
  margin-left: 10px;
}

nav a {
  color: seashell;
  margin: 0 15px;
  text-decoration: underline;
}

/* Hero */
.hero {
  margin-top: 69px;
  height: 700px;
  background-image: url("background.jpg");
  background-size: cover;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  background-color: black;
  padding: 20px;
}

/* Featured */
.featured {
  margin: 60px auto;
  width: 1000px;
}

.tea-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.tea {
  margin: 10px;
}

.tea img {
  height: 200px;
  width: 300px;
}

/* Locations */
.locations {
  height: 500px;
  background-image: url("locations.jpg");
  background-size: cover;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.location-container {
  display: flex;
  justify-content: center;
}

.location {
  background-color: black;
  margin: 15px;
  padding: 20px;
  width: 300px;
  opacity: 0.9;
}

/* Footer */
footer {
  margin-top: 40px;
}

footer .copyright {
  margin-top: 20px;
  font-size: 12px;
}